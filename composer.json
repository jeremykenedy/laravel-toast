{
    "name": "jeremykenedy/laravel-toast",
    "description": "Multi-framework toast notifications for Laravel with Tailwind, Bootstrap 5, Bootstrap 4, Blade, Livewire, Vue, React, and Svelte support.",
    "license": "MIT",
    "keywords": ["laravel", "toast", "notifications", "flash", "tailwind", "bootstrap", "livewire", "vue", "react", "svelte"],
    "authors": [
        {
            "name": "Jeremy Kenedy",
            "email": "jeremykenedy@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2|^8.3",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/view": "^10.0|^11.0|^12.0|^13.0",
        "jeremykenedy/laravel-ui-kit": "^1.0|"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.0|^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "Jeremykenedy\\LaravelToast\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Jeremykenedy\\LaravelToast\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Jeremykenedy\\LaravelToast\\Providers\\ToastServiceProvider"
            ],
            "aliases": {
                "Toast": "Jeremykenedy\\LaravelToast\\Facades\\Toast"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
